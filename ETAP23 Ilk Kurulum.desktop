[Desktop Entry]
Version=1.0
Type=Application
Name=ETAP23 İlk Kurulum
Comment=ETAP23 kurulum sihirbazını yönetici yetkisi ile başlatır
Exec=/bin/sh -c "desktop_file=\$1; script_dir=\$(CDPATH= cd -- \"\$(dirname -- \"\$desktop_file\")\" && pwd); launcher=\"\$script_dir/setup_etap23_launcher.sh\"; if [ ! -x \"\$launcher\" ]; then printf 'HATA: Baslatici bulunamadi: %s\n' \"\$launcher\"; printf 'Pencereyi kapatmadan once Enter tusuna basin...'; read -r _; exit 1; fi; ETAP23_RUNTIME_DIR=\"\$script_dir\" exec \"\$launcher\"" sh %k
Icon=preferences-system
Terminal=true
StartupNotify=true
Categories=System;Settings;
