[Desktop Entry]
Version=1.0
Type=Application
Name=ETA Kayıt düzelt/sıfırla
Comment=ETA Kayit ve Ahenk kayit sorunlarini grafik arayuzden temizle veya sifirla
Exec=/bin/sh -c "desktop_file=\$1; script_dir=\$(CDPATH= cd -- \"\$(dirname -- \"\$desktop_file\")\" && pwd); script=\"\$script_dir/ahenk_kaldir.sh\"; if [ ! -x \"\$script\" ]; then printf 'HATA: Betik bulunamadi: %s\n' \"\$script\"; printf 'Pencereyi kapatmadan once Enter tusuna basin...'; read -r _; exit 1; fi; ETAP23_RUNTIME_DIR=\"\$script_dir\" exec \"\$script\" --gui" sh %k
Icon=edit-clear
Terminal=true
StartupNotify=true
Categories=System;Settings;
