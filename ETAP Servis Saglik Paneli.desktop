[Desktop Entry]
Version=1.0
Type=Application
Name=ETAP Servis Saglik Paneli
Comment=Temel servis ve timer durumlarini kontrol et veya yeniden baslat
Exec=/bin/sh -c "desktop_file=\$1; script_dir=\$(CDPATH= cd -- \"\$(dirname -- \"\$desktop_file\")\" && pwd); script=\"\$script_dir/servis_saglik_paneli.sh\"; if [ ! -x \"\$script\" ]; then printf 'HATA: Betik bulunamadi: %s\n' \"\$script\"; printf 'Pencereyi kapatmadan once Enter tusuna basin...'; read -r _; exit 1; fi; ETAP23_RUNTIME_DIR=\"\$script_dir\" exec \"\$script\" --gui" sh %k
Icon=utilities-system-monitor
Terminal=true
StartupNotify=true
Categories=System;Settings;
